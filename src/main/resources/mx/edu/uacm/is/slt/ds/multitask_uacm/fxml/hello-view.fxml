<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="900.0" spacing="20.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="mx.edu.uacm.is.slt.ds.multitask_uacm.controlador.PantallaPrincipalController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <Button fx:id="buttonMostrarOperciones" mnemonicParsing="false" text="Mostrar Operaciones"  onAction="#onButtonMostrarOperacioes" />

    <Button onAction="#onHelloButtonClick" text="Hola bienvenidos al proyecto MultiTask..." />
    <Button fx:id="botonVisorEditorOperacion" onAction="#onButtonVistaEditorOperacion" text="Editar Operaciones" />

    <Label fx:id="texto" />
</VBox>
